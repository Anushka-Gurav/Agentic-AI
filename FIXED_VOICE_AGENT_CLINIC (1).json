        224,
        0
      ],
      "id": "0f05d023-42ff-4332-8f34-580c2ad18359",
      "name": "AI Agent"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "{\n  \"response\": \"I understand you want to book an appointment. To do that, I need a bit more information from you. Please tell me:\n\n1.  **What is the desired start time for the appointment?** (e.g., \"tomorrow at 10 AM\", \"June 15th at 2 PM\")\n2.  **What is the desired end time for the appointment?** (e.g., \"11 AM\", \"3 PM\")\n3.  **What is the reason for the visit?** (e.g., \"routine check-up\", \"consultation about a persistent cough\")\n\nOnce I have these details, I can proceed with booking your appointment.\"\n}",
        "options": {}
      },
